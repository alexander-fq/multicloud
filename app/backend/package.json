{
  "name": "govtech-cloud-migration-backend",
  "version": "1.0.0",
  "description": "Multi-cloud backend architecture for government digital transformation platform with automated cloud migration tools",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "npx nodemon server.js",
    "dev:node": "node --watch server.js",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "migrate:scan": "node src/migration/scanner/cli-scan.js",
    "migrate:plan": "node src/migration/mapper/cli-plan.js"
  },
  "keywords": [
    "govtech",
    "multi-cloud",
    "cloud-migration",
    "aws",
    "oci",
    "gcp",
    "azure",
    "api",
    "postgresql",
    "express",
    "node"
  ],
  "author": "Alexander",
  "license": "MIT",
  "dependencies": {
    "aws-sdk": "^1.18.0",
    "compression": "^1.8.1",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "7.1.5",
    "helmet": "7.1.0",
    "joi": "17.11.0",
    "morgan": "^1.10.1",
    "oci-common": "^2.125.1",
    "oci-containerengine": "^2.125.1",
    "oci-core": "^2.125.1",
    "oci-database": "^2.125.1",
    "oci-identity": "^2.125.1",
    "oci-monitoring": "^2.125.1",
    "oci-objectstorage": "^2.125.1",
    "oci-sdk": "^2.125.1",
    "pg": "8.11.3",
    "pg-hstore": "2.3.4",
    "winston": "3.11.0"
  },
  "devDependencies": {
    "eslint": "8.55.0",
    "jest": "29.7.0",
    "nodemon": "3.0.2",
    "supertest": "6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testTimeout": 10000
  }
}
