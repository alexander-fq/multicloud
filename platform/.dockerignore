# Dependencias - son instaladas dentro del contenedor, no enviar al build context
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Control de versiones
.git/
.gitignore

# Variables de entorno y secretos
.env
.env.*
!.env.example

# Logs
*.log
logs/

# Archivos de sistema operativo
.DS_Store
Thumbs.db

# Archivos de tests (no necesarios para build de produccion)
tests/
**/*.test.js
**/*.spec.js
coverage/

# Artifacts de build del frontend (se generan dentro del contenedor)
app/frontend/dist/
app/frontend/.vite/

# Cache
.npm/
.cache/

# Archivos de IDE
.vscode/
.idea/
*.swp
*.swo

# Archivos temporales de Zone.Identifier (Windows)
*:Zone.Identifier
